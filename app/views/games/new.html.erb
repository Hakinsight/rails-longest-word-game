<div class="container py-5">
  <h1 class="mb-4">New game</h1>

  <div class="d-flex mb-4">
    <% @letters.each do |letter| %>
      <div class="bg-primary text-white font-weight-bold p-3 m-1 shadow-sm text-center" style="width: 50px;">
        <%= letter %>
      </div>
    <% end %>

  </div>

<div>
  <form action="/score" method="POST" data-turbo="false" class="mt-4">
  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
  <%= hidden_field_tag :letters, @letters.join(" ") %>

  <div class="input-group">
    <input type="text" name="word" class="form-control" placeholder="Quel est votre mot ?">
    <button type="submit" class="btn btn-primary">Jouer</button>
  </div>
</form>
</div>

  </div>
